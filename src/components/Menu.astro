---
import menuKo from "../data/menu.json";
import menuEn from "../data/en/menu.json";
import { pexelsSrc, pexelsSrcset } from "../lib/pexels";

interface Props { lang?: "ko" | "en"; }
const { lang = "ko" } = Astro.props;
const menu = lang === "en" ? menuEn : menuKo;
---

<section id="menu" class="py-24 bg-white">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="reveal text-3xl md:text-4xl font-extrabold text-center text-stone-900">
      {menu.title}
    </h2>
    <p class="reveal mt-4 text-center text-stone-600 max-w-2xl mx-auto">
      {menu.subtitle}
    </p>

    <div data-menu-tabs class="mt-12">
      <!-- Tab buttons -->
      <div role="tablist" aria-label={menu.title} class="reveal flex flex-wrap justify-center gap-2 md:gap-3 border-b border-stone-200">
        {menu.categories.map((cat) => (
          <button
            type="button"
            data-tab={cat.name}
            role="tab"
            aria-selected="false"
            class="menu-tab px-5 py-3 text-sm md:text-base font-semibold text-stone-600 border-b-2 border-transparent hover:text-[var(--color-brand)] transition"
          >
            {cat.name}
          </button>
        ))}
      </div>

      <!-- Tab panels — always one row, horizontal scroll on small screens -->
      <div class="mt-10 relative">
        {menu.categories.map((cat) => (
          <div data-panel={cat.name} class="tab-panel hidden">
            <div
              data-reveal-children
              class="flex gap-3 md:gap-4 overflow-x-auto md:overflow-visible -mx-4 px-4 pb-2 md:pb-0 snap-x snap-mandatory"
            >
              {cat.items.map((item) => (
                <figure
                  class="lift zoom-on-hover shrink-0 snap-start w-32 sm:w-36 md:flex-1 md:w-auto md:min-w-0 text-center"
                >
                  <div class={`aspect-square rounded-xl overflow-hidden ring-1 ring-stone-200 ${
                    (cat as any).style === "icon"
                      ? "bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-dark)] flex items-center justify-center text-white"
                      : "bg-stone-100"
                  }`}>
                    {(cat as any).style === "icon" ? (
                      <>
                        {(item as any).icon === "noodle-bowl" && (
                          <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 12h18a9 9 0 0 1-18 0z"/>
                            <line x1="3" y1="12" x2="21" y2="12"/>
                            <path d="M8 8c0-2 1-4 2-4"/>
                            <path d="M12 8c0-2 1-4 2-4"/>
                            <path d="M16 8c0-2 1-4 2-4"/>
                          </svg>
                        )}
                        {(item as any).icon === "noodle-soup" && (
                          <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M2 12h20a10 10 0 0 1-20 0z"/>
                            <line x1="2" y1="12" x2="22" y2="12"/>
                            <path d="M6 6c0 1 2 1 2 3"/>
                            <path d="M11 4c0 2 2 2 2 4"/>
                            <path d="M16 6c0 1 2 1 2 3"/>
                          </svg>
                        )}
                        {(item as any).icon === "kimchi" && (
                          <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <ellipse cx="12" cy="18" rx="9" ry="3"/>
                            <path d="M3 6c2 1 4 2 9 2s7-1 9-2"/>
                            <path d="M3 6v12"/>
                            <path d="M21 6v12"/>
                            <path d="M9 6c0-2 1-3 3-3s3 1 3 3"/>
                          </svg>
                        )}
                        {(item as any).icon === "leaf" && (
                          <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M11 20A7 7 0 0 1 4 13c0-5 4-9 9-9 5 0 7 4 7 7a7 7 0 0 1-7 7c-3 0-5-1-6-3"/>
                            <path d="M12 19V8"/>
                          </svg>
                        )}
                        {(item as any).icon === "scallion" && (
                          <svg width="46" height="46" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M8 22V10c0-2 1-3 2-3s2 1 2 3v12"/>
                            <path d="M10 7c-1-1-1-3 0-4s2-1 3 0"/>
                            <path d="M14 22V12c0-2 1-3 2-3"/>
                            <path d="M16 9c-1-1-1-3 0-4"/>
                            <path d="M4 22V14c0-2 1-3 2-3"/>
                            <path d="M6 11c-1-1-1-3 0-4"/>
                          </svg>
                        )}
                      </>
                    ) : (
                      <img
                        src={pexelsSrc((item as any).image, 600)}
                        srcset={pexelsSrcset((item as any).image, [320, 600, 900])}
                        sizes="(min-width: 768px) 33vw, 50vw"
                        alt={item.name}
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover"
                      />
                    )}
                  </div>
                  <figcaption class="mt-3 text-sm font-semibold text-stone-800">{item.name}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .menu-tab.is-active {
    color: var(--color-brand);
    border-bottom-color: var(--color-brand);
  }
</style>
