---
import strategyKo from "../data/strategy.json";
import strategyEn from "../data/en/strategy.json";

interface Props { lang?: "ko" | "en"; }
const { lang = "ko" } = Astro.props;
const strategy = lang === "en" ? strategyEn : strategyKo;
---

<section id="strategy" class="relative py-24 bg-stone-950 text-white overflow-hidden">
  <!-- Parallax background -->
  <div class="absolute inset-0 overflow-hidden">
    <div
      data-parallax
      data-parallax-speed="0.12"
      data-bg-src={strategy.bgImage}
      class="absolute inset-0 -top-16 -bottom-16 bg-cover bg-center opacity-30 bg-stone-900"
    ></div>
    <div class="absolute inset-0 bg-gradient-to-b from-stone-950/85 via-stone-950/95 to-stone-950"></div>
  </div>

  <div class="relative z-10 mx-auto max-w-6xl px-4">
    <h2 class="reveal text-3xl md:text-4xl font-extrabold text-center">
      {strategy.title}
    </h2>
    <p class="reveal mt-4 text-center text-stone-300 max-w-3xl mx-auto">
      {strategy.subtitle}
    </p>

    <div data-reveal-children class="mt-14 grid gap-6 md:grid-cols-3">
      {strategy.pillars.map((p) => (
        <div class="lift rounded-2xl border border-stone-700 bg-stone-800 p-6 hover:border-[var(--color-accent)] transition">
          <h3 class="text-lg font-bold text-[var(--color-accent)]">{p.title}</h3>
          <p class="mt-2 text-sm text-stone-300">{p.description}</p>
        </div>
      ))}
    </div>

    <!-- Supply chain — icons only, no photos -->
    <div class="mt-24">
      <h3 class="reveal text-2xl md:text-3xl font-bold text-center">{strategy.supply.title}</h3>
      <p class="reveal mt-3 text-center text-stone-300">{strategy.supply.subtitle}</p>
      <div data-reveal-children class="mt-10 grid gap-4 md:grid-cols-3">
        {strategy.supply.items.map((item, i) => (
          <div class="lift rounded-2xl bg-stone-900 ring-1 ring-stone-700 p-8 flex flex-col items-center text-center">
            <div class="inline-flex w-20 h-20 items-center justify-center rounded-full bg-[var(--color-brand)]/15 ring-1 ring-[var(--color-brand)]/40 text-[var(--color-accent)]">
              {i === 0 && (
                /* fish icon — premium eel */
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M2 12c3-4 7-6 11-6 3 0 6 1 9 4-3 3-6 4-9 4-4 0-8-2-11-2Z"/>
                  <path d="M22 10c-1 1-2 2-3 2 0-1 1-2 3-2Z"/>
                  <circle cx="16" cy="10" r="0.9" fill="currentColor"/>
                  <path d="M2 12c2 1 4 2 5 4"/>
                </svg>
              )}
              {i === 1 && (
                /* knife icon — boneless prep */
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 21l5-5"/>
                  <path d="M14.5 2.5 21 9 9 21l-6-6Z"/>
                  <path d="M14.5 2.5 9 8"/>
                </svg>
              )}
              {i === 2 && (
                /* truck icon — stable logistics */
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="6" width="13" height="11" rx="1"/>
                  <path d="M14 9h4l3 4v4h-7Z"/>
                  <circle cx="6"  cy="18" r="2"/>
                  <circle cx="17" cy="18" r="2"/>
                </svg>
              )}
            </div>
            <div class="mt-5 flex items-center gap-2">
              <span class="text-xs font-bold rounded-full px-2 py-0.5 bg-[var(--color-brand)] text-white">
                STEP {i + 1}
              </span>
              <h4 class="font-bold text-[var(--color-accent)]">{item.title}</h4>
            </div>
            <p class="mt-3 text-sm text-stone-300">{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
