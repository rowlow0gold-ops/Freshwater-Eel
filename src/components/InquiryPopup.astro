---
import popupKo from "../data/popup.json";
import popupEn from "../data/en/popup.json";
import siteKo from "../data/site.json";
import siteEn from "../data/en/site.json";
import inquiryKo from "../data/inquiry.json";
import inquiryEn from "../data/en/inquiry.json";

interface Props {
  lang?: "ko" | "en";
}
const { lang = "ko" } = Astro.props;
const popup = (lang === "en" ? popupEn : popupKo).inquiry;
const site = lang === "en" ? siteEn : siteKo;
const copy = lang === "en" ? inquiryEn : inquiryKo;
const t = lang === "en";

const inquiry = (site as any).inquiry || {};
const workerEndpoint: string = inquiry.workerEndpoint || "";
const clientId: string = inquiry.clientId || "";
const turnstileSiteKey: string = inquiry.turnstileSiteKey || "";
const configured = Boolean(workerEndpoint && turnstileSiteKey && clientId);
---

<div
  data-popup="inquiry"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/55 backdrop-blur-sm p-3 md:p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="inquiry-popup-title"
>
  <div class="relative max-w-2xl w-full bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[92vh]">
    <button
      type="button"
      data-popup-close
      aria-label={t ? "Close" : "닫기"}
      class="absolute top-3 right-3 z-10 w-9 h-9 rounded-full bg-white/90 text-stone-600 hover:text-stone-900 hover:bg-white flex items-center justify-center text-xl shadow"
    >
      ×
    </button>

    <!-- Header -->
    <div class="bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-dark)] text-white px-6 md:px-7 py-4 shrink-0">
      <p class="text-[10px] tracking-[0.3em] font-bold opacity-90 uppercase">
        {popup.kicker}
      </p>
      <h3 id="inquiry-popup-title" class="mt-1 text-lg md:text-xl font-extrabold leading-tight">
        {popup.title}
        {popup.subtitle && (
          <span class="ml-2 text-sm md:text-base font-bold text-[var(--color-accent)]">
            · {popup.subtitle}
          </span>
        )}
      </h3>
    </div>

    <!-- Body -->
    <div class="flex-1 overflow-y-auto px-5 md:px-6 py-4">
      <!-- Proposal download (compact) -->
      {popup.proposalHref && (
        <a
          href={popup.proposalHref}
          target="_blank"
          rel="noopener"
          class="mb-4 flex items-center gap-3 rounded-xl bg-stone-50 border border-stone-200 px-3 py-2 hover:border-[var(--color-brand)] hover:bg-white transition group"
        >
          <span class="inline-flex w-8 h-8 items-center justify-center rounded-full bg-[var(--color-brand)] text-white shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
          </span>
          <span class="flex-1 text-sm font-bold text-stone-900">{popup.proposalLabel}</span>
          <span class="text-stone-400 group-hover:text-[var(--color-brand)] transition">→</span>
        </a>
      )}

      {configured ? (
        <form
          data-inquiry-form
          data-worker-endpoint={workerEndpoint}
          data-client-id={clientId}
          data-lang={lang}
          class="space-y-3"
          novalidate
        >
          <!-- Honeypot: hidden from real users, bots will fill it. Server discards. -->
          <div class="absolute -left-[9999px] w-0 h-0 overflow-hidden" aria-hidden="true">
            <label>
              Website
              <input type="text" name="website" tabindex="-1" autocomplete="off" />
            </label>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <label class="block">
              <span class="block text-xs font-bold text-stone-600 mb-1">
                {copy.fields.name.label} <span class="text-[var(--color-brand)]">*</span>
              </span>
              <input
                type="text"
                name="name"
                required
                placeholder={copy.fields.name.placeholder}
                class="w-full rounded-lg border border-stone-300 px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:ring-2 focus:ring-[var(--color-brand)]/20 outline-none transition"
              />
            </label>
            <label class="block">
              <span class="block text-xs font-bold text-stone-600 mb-1">
                {copy.fields.phone.label} <span class="text-[var(--color-brand)]">*</span>
              </span>
              <input
                type="tel"
                name="phone"
                required
                placeholder={copy.fields.phone.placeholder}
                class="w-full rounded-lg border border-stone-300 px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:ring-2 focus:ring-[var(--color-brand)]/20 outline-none transition"
              />
            </label>
          </div>

          <label class="block">
            <span class="block text-xs font-bold text-stone-600 mb-1">
              {copy.fields.email.label}
            </span>
            <input
              type="email"
              name="email"
              placeholder={copy.fields.email.placeholder}
              class="w-full rounded-lg border border-stone-300 px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:ring-2 focus:ring-[var(--color-brand)]/20 outline-none transition"
            />
          </label>

          <label class="block">
            <span class="block text-xs font-bold text-stone-600 mb-1">
              {copy.fields.region.label} <span class="text-[var(--color-brand)]">*</span>
            </span>
            <input
              type="text"
              name="region"
              required
              placeholder={copy.fields.region.placeholder}
              class="w-full rounded-lg border border-stone-300 px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:ring-2 focus:ring-[var(--color-brand)]/20 outline-none transition"
            />
          </label>

          <label class="block">
            <span class="block text-xs font-bold text-stone-600 mb-1">
              {copy.fields.message.label} <span class="text-[var(--color-brand)]">*</span>
            </span>
            <textarea
              name="message"
              required
              rows="4"
              placeholder={copy.fields.message.placeholder}
              class="w-full rounded-lg border border-stone-300 px-3 py-2 text-sm focus:border-[var(--color-brand)] focus:ring-2 focus:ring-[var(--color-brand)]/20 outline-none transition resize-none"
            ></textarea>
          </label>

          <label class="flex items-start gap-2 text-xs text-stone-700">
            <input
              type="checkbox"
              name="consent"
              required
              class="mt-0.5 w-4 h-4 rounded border-stone-300 text-[var(--color-brand)] focus:ring-[var(--color-brand)]/30"
            />
            <span>{copy.consent}</span>
          </label>

          <!-- Cloudflare Turnstile widget -->
          <div
            class="cf-turnstile"
            data-sitekey={turnstileSiteKey}
            data-theme="light"
            data-size="flexible"
          ></div>

          <!-- Status message -->
          <div data-inquiry-status class="hidden text-sm rounded-lg px-3 py-2"></div>

          <button
            type="submit"
            data-inquiry-submit
            data-label-default={copy.submit}
            data-label-submitting={copy.submitting}
            data-success={copy.success}
            data-error-generic={copy.errorGeneric}
            data-error-turnstile={copy.errorTurnstile}
            data-error-ratelimit={copy.errorRateLimit}
            data-error-consent={copy.errorConsent}
            class="w-full rounded-lg bg-[var(--color-brand)] hover:bg-[var(--color-brand-dark)] text-white font-bold py-3 transition disabled:opacity-60 disabled:cursor-not-allowed"
          >
            {copy.submit}
          </button>
        </form>
      ) : (
        <div class="rounded-xl bg-amber-50 border border-amber-200 p-5 text-sm text-amber-800">
          {t ? (
            <>
              <p class="font-semibold">Inquiry form not yet configured.</p>
              <p class="mt-1">
                Configure <code>inquiry.workerEndpoint</code>, <code>inquiry.clientId</code>,
                and <code>inquiry.turnstileSiteKey</code> in <code>site.json</code>.
              </p>
            </>
          ) : (
            <>
              <p class="font-semibold">문의 양식이 아직 설정되지 않았습니다.</p>
              <p class="mt-1">
                <code>site.json</code>의 <code>inquiry</code> 항목에
                Worker 엔드포인트, 클라이언트 ID, Turnstile Site Key를 입력해 주세요.
              </p>
            </>
          )}
        </div>
      )}
    </div>

    <!-- Footer button -->
    <div class="flex border-t border-stone-200 text-sm shrink-0">
      <button
        type="button"
        data-popup-close
        class="flex-1 py-3 font-semibold text-[var(--color-brand)] hover:bg-stone-50 transition"
      >
        {t ? "Close" : "닫기"}
      </button>
    </div>
  </div>
</div>

<!-- Turnstile API: loads on every page that uses this component -->
<script
  is:inline
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer
></script>
