---
import legalKo from "../data/legal.json";
import legalEn from "../data/en/legal.json";

interface Props {
  name: "terms" | "privacy";
  lang?: "ko" | "en";
}
const { name, lang = "ko" } = Astro.props;
const legal = lang === "en" ? legalEn : legalKo;
const data = legal[name];
const t = lang === "en";
---

<div
  data-popup={name}
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/55 backdrop-blur-sm p-3 md:p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby={`${name}-popup-title`}
>
  <div class="relative max-w-2xl w-full bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col max-h-[88vh]">
    <button
      type="button"
      data-popup-close
      aria-label={t ? "Close" : "닫기"}
      class="absolute top-3 right-3 z-10 w-9 h-9 rounded-full bg-white/90 text-stone-600 hover:text-stone-900 hover:bg-white flex items-center justify-center text-xl shadow"
    >
      ×
    </button>

    <!-- Header -->
    <div class="bg-stone-900 text-white px-6 md:px-7 py-5 md:py-6 shrink-0">
      <h3 id={`${name}-popup-title`} class="text-xl md:text-2xl font-extrabold leading-tight">
        {data.title}
      </h3>
      {data.subtitle && (
        <p class="mt-1 text-sm text-stone-300">{data.subtitle}</p>
      )}
      {data.updated && (
        <p class="mt-1 text-[11px] text-stone-400">{data.updated}</p>
      )}
    </div>

    <!-- Body -->
    <div class="flex-1 overflow-y-auto px-6 md:px-7 py-5 space-y-5">
      {data.sections.map((s) => (
        <section>
          <h4 class="text-sm md:text-base font-bold text-stone-900">{s.heading}</h4>
          <p class="mt-1.5 text-sm leading-relaxed text-stone-700 whitespace-pre-line">{s.body}</p>
        </section>
      ))}
    </div>

    <!-- Footer (no hide-1d) -->
    <div class="flex border-t border-stone-200 text-sm shrink-0">
      <button
        type="button"
        data-popup-close
        class="flex-1 py-3 font-semibold text-[var(--color-brand)] hover:bg-stone-50 transition"
      >
        {t ? "Close" : "닫기"}
      </button>
    </div>
  </div>
</div>
