---
import Layout from "../layouts/Layout.astro";
---

<Layout
  lang="ko"
  path="/404"
  title="404 — 페이지를 찾을 수 없습니다"
  description="요청하신 페이지를 찾을 수 없습니다. 본가민물장어 홈으로 이동해 주세요."
>
  <main class="min-h-[60vh] flex items-center justify-center px-4 py-20">
    <div class="max-w-xl text-center">
      <p class="text-sm font-bold tracking-[0.3em] text-[var(--color-brand)]">404</p>
      <h1 class="mt-3 text-4xl md:text-5xl font-extrabold text-stone-900">
        페이지를 찾을 수 없습니다
      </h1>
      <p class="mt-4 text-stone-600 leading-relaxed">
        주소가 변경되었거나 더 이상 사용되지 않는 페이지일 수 있어요.<br />
        본가민물장어 홈으로 돌아가 메뉴·매장·창업 안내를 확인해 주세요.
      </p>
      <p class="mt-2 text-stone-500 text-sm">
        Page not found. The URL may have changed or no longer exists.
      </p>

      <div class="mt-8 flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center rounded-full bg-[var(--color-brand)] text-white px-6 py-3 font-bold hover:bg-[var(--color-brand-dark)] transition"
        >
          홈으로 가기
        </a>
        <a
          href="/en/"
          class="inline-flex items-center justify-center rounded-full border border-stone-300 text-stone-700 px-6 py-3 font-bold hover:border-stone-500 transition"
        >
          English home
        </a>
      </div>

      <ul class="mt-10 grid grid-cols-2 sm:grid-cols-3 gap-2 text-sm text-stone-500">
        <li><a href="/#menu" class="hover:text-[var(--color-brand)]">메뉴</a></li>
        <li><a href="/#store" class="hover:text-[var(--color-brand)]">매장 안내</a></li>
        <li><a href="/#franchise" class="hover:text-[var(--color-brand)]">창업 안내</a></li>
        <li><a href="/#strategy" class="hover:text-[var(--color-brand)]">운영 전략</a></li>
        <li><a href="/#brand" class="hover:text-[var(--color-brand)]">브랜드</a></li>
        <li><a href="/#notice" class="hover:text-[var(--color-brand)]">공지</a></li>
      </ul>
    </div>
  </main>
</Layout>
