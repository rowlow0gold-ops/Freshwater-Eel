---
import franchiseKo from "../data/franchise.json";
import franchiseEn from "../data/en/franchise.json";
import siteKo from "../data/site.json";
import siteEn from "../data/en/site.json";

interface Props { lang?: "ko" | "en"; }
const { lang = "ko" } = Astro.props;
const franchise = lang === "en" ? franchiseEn : franchiseKo;
const site = lang === "en" ? siteEn : siteKo;

const groups = [...new Set(franchise.costs.map((c) => c.group))];

const t = (ko: string, en: string) => (lang === "en" ? en : ko);
const waivedKeyword = lang === "en" ? "Waived" : "면제";
---

<section id="franchise" class="py-24 bg-stone-100">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="reveal text-3xl md:text-4xl font-extrabold text-center text-stone-900">
      {franchise.title}
    </h2>
    <p class="reveal mt-4 text-center text-stone-600 max-w-2xl mx-auto">
      {franchise.subtitle}
    </p>

    <div class="reveal mt-8 flex justify-center gap-3 text-sm font-semibold text-stone-600">
      {franchise.pillars.map((p) => <span class="px-3 py-1 rounded-full bg-white">{p}</span>)}
    </div>

    <h3 class="reveal mt-16 text-xl md:text-2xl font-bold text-center text-stone-900">
      {t("가맹점 창업비용", "Franchise opening costs")}
    </h3>
    <div class="reveal mt-6 overflow-hidden rounded-2xl border border-stone-200 bg-white">
      <table class="w-full text-sm">
        <thead class="bg-stone-900 text-white">
          <tr>
            <th class="px-4 py-3 text-left">{t("구분", "Group")}</th>
            <th class="px-4 py-3 text-left">{t("항목", "Item")}</th>
            <th class="px-4 py-3 text-left">{t("금액", "Original")}</th>
            <th class="px-4 py-3 text-left">{t("적용", "Applied")}</th>
          </tr>
        </thead>
        <tbody>
          {groups.map((g) => (
            franchise.costs
              .filter((c) => c.group === g)
              .map((c, i) => (
                <tr class="border-t border-stone-100">
                  {i === 0 && (
                    <td
                      rowspan={franchise.costs.filter((x) => x.group === g).length}
                      class="px-4 py-3 font-semibold text-stone-700 bg-stone-50 align-top"
                    >
                      {g}
                    </td>
                  )}
                  <td class="px-4 py-3 text-stone-800">{c.item}</td>
                  <td class="px-4 py-3 text-stone-500 line-through">{c.original || "-"}</td>
                  <td class="px-4 py-3 font-semibold text-[var(--color-brand)]">{c.applied}</td>
                </tr>
              ))
          ))}
        </tbody>
      </table>
    </div>

    <h3 class="reveal mt-20 text-xl md:text-2xl font-bold text-center text-stone-900">
      {t("가맹점 창업혜택", "Franchise opening incentives")}
    </h3>
    <div data-reveal-children class="mt-6 grid gap-6 md:grid-cols-3">
      {franchise.promotions.map((p) => (
        <div class="lift rounded-2xl bg-white border border-stone-200 p-6 shadow-sm">
          <div class="flex items-center justify-between">
            <h4 class="font-bold text-stone-900">{p.label}</h4>
            <span class="text-xs font-semibold px-2 py-1 rounded-full bg-[var(--color-brand)]/10 text-[var(--color-brand)]">
              {p.status}
            </span>
          </div>
          <div class="mt-4 space-y-2 text-sm">
            {p.benefits.map((b) => (
              <div class="flex justify-between border-b border-stone-100 py-1.5">
                <span class="text-stone-600">{b.item}</span>
                <span>
                  <span class="text-stone-400 line-through mr-2">{b.original}</span>
                  <span class={b.applied === waivedKeyword ? "font-bold text-[var(--color-brand)]" : "font-semibold text-stone-800"}>
                    {b.applied}
                  </span>
                </span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>

    <!-- CTA — solid brand color, no photo -->
    <div class="reveal mt-16 rounded-3xl overflow-hidden text-white bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-dark)]">
      <div class="p-10 md:p-14 text-center">
        <p class="text-sm tracking-widest text-white/80 font-semibold">CONSULTATION</p>
        <h3 class="mt-3 text-2xl md:text-3xl font-extrabold">
          {t("창업 후 어려움을 겪고 계신가요?", "Stuck after opening your restaurant?")}
        </h3>
        <p class="mt-3 text-white/90">
          {t(
            "대한민국 외식업 사업자분들의 성공창업을 본가가 든든하게 지원합니다.",
            "Bonga supports F&B owners with proven systems for a successful launch and beyond."
          )}
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a
            href={`tel:${site.phone}`}
            class="pulse rounded-full bg-white px-6 py-3 text-sm md:text-base font-bold text-[var(--color-brand)] hover:bg-stone-100 transition"
          >
            {t("창업상담", "Talk to a franchise advisor")} {site.phone}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
