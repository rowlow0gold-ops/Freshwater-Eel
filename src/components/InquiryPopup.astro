---
import popupKo from "../data/popup.json";
import popupEn from "../data/en/popup.json";
import siteKo from "../data/site.json";
import siteEn from "../data/en/site.json";

interface Props {
  lang?: "ko" | "en";
}
const { lang = "ko" } = Astro.props;
const popup = (lang === "en" ? popupEn : popupKo).inquiry;
const site = lang === "en" ? siteEn : siteKo;
const t = lang === "en";

const formUrl: string = (site as any).googleFormEmbedUrl || "";
const turnstileSiteKey: string = (site as any).turnstileSiteKey || "";
---

<div
  data-popup="inquiry"
  class="fixed inset-0 z-[60] hidden items-center justify-center bg-black/55 backdrop-blur-sm p-3 md:p-4"
  role="dialog"
  aria-modal="true"
  aria-labelledby="inquiry-popup-title"
>
  <div class="relative max-w-3xl w-full bg-white rounded-2xl shadow-2xl overflow-hidden flex flex-col h-[92vh] max-h-[92vh]">
    <button
      type="button"
      data-popup-close
      aria-label={t ? "Close" : "닫기"}
      class="absolute top-3 right-3 z-10 w-9 h-9 rounded-full bg-white/90 text-stone-600 hover:text-stone-900 hover:bg-white flex items-center justify-center text-xl shadow"
    >
      ×
    </button>

    <!-- Header — compact so iframe gets more height -->
    <div class="bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-dark)] text-white px-6 md:px-7 py-4 shrink-0">
      <p class="text-[10px] tracking-[0.3em] font-bold opacity-90 uppercase">
        {popup.kicker}
      </p>
      <h3 id="inquiry-popup-title" class="mt-1 text-lg md:text-xl font-extrabold leading-tight">
        {popup.title}
        {popup.subtitle && (
          <span class="ml-2 text-sm md:text-base font-bold text-[var(--color-accent)]">
            · {popup.subtitle}
          </span>
        )}
      </h3>
    </div>

    <!-- Body -->
    <div class="flex-1 flex flex-col min-h-0 px-4 md:px-5 py-3">
      <!-- Proposal download (compact) -->
      {popup.proposalHref && (
        <a
          href={popup.proposalHref}
          target="_blank"
          rel="noopener"
          class="shrink-0 mb-3 flex items-center gap-3 rounded-xl bg-stone-50 border border-stone-200 px-3 py-2 hover:border-[var(--color-brand)] hover:bg-white transition group"
        >
          <span class="inline-flex w-8 h-8 items-center justify-center rounded-full bg-[var(--color-brand)] text-white shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
              <polyline points="7 10 12 15 17 10" />
              <line x1="12" y1="15" x2="12" y2="3" />
            </svg>
          </span>
          <span class="flex-1 text-sm font-bold text-stone-900">{popup.proposalLabel}</span>
          <span class="text-stone-400 group-hover:text-[var(--color-brand)] transition">→</span>
        </a>
      )}

      {formUrl ? (
        <div
          class="flex-1 min-h-0 rounded-xl overflow-hidden border border-stone-200 flex flex-col"
          data-inquiry-gate
          data-form-url={formUrl}
        >
          {turnstileSiteKey ? (
            <!-- Turnstile gate: shows first; iframe is hidden until verified -->
            <div data-inquiry-challenge class="flex-1 flex flex-col items-center justify-center gap-4 p-6 text-center">
              <div class="space-y-1">
                <p class="text-sm font-bold text-stone-900">
                  {t ? "Quick security check" : "잠시만요, 봇 방지 확인이 필요해요"}
                </p>
                <p class="text-xs text-stone-500">
                  {t ? "Please complete the check to load the inquiry form." : "확인을 완료하시면 문의 양식이 표시됩니다."}
                </p>
              </div>
              <div
                class="cf-turnstile"
                data-sitekey={turnstileSiteKey}
                data-theme="light"
                data-callback="onInquiryTurnstileSuccess"
              ></div>
            </div>
          ) : null}

          <!-- Google Forms iframe — only revealed after Turnstile passes (or always, if no key configured) -->
          <iframe
            data-inquiry-iframe
            data-src={formUrl}
            src={turnstileSiteKey ? "about:blank" : formUrl}
            class={`w-full h-full block ${turnstileSiteKey ? "hidden" : ""}`}
            frameborder="0"
            marginheight="0"
            marginwidth="0"
            title={t ? "Inquiry form" : "문의 양식"}
          >
            {t ? "Loading…" : "불러오는 중…"}
          </iframe>
        </div>
      ) : (
        <div class="rounded-xl bg-amber-50 border border-amber-200 p-5 text-sm text-amber-800">
          {t ? (
            <>
              <p class="font-semibold">Inquiry form not yet configured.</p>
              <p class="mt-1">
                Paste your Google Form embed URL into <code>googleFormEmbedUrl</code> in <code>site.json</code>.
              </p>
            </>
          ) : (
            <>
              <p class="font-semibold">문의 양식이 아직 설정되지 않았습니다.</p>
              <p class="mt-1">
                <code>site.json</code>의 <code>googleFormEmbedUrl</code>에 Google Form 주소를 입력해 주세요.
              </p>
            </>
          )}
        </div>
      )}
    </div>

    <!-- Footer button -->
    <div class="flex border-t border-stone-200 text-sm shrink-0">
      <button
        type="button"
        data-popup-close
        class="flex-1 py-3 font-semibold text-[var(--color-brand)] hover:bg-stone-50 transition"
      >
        {t ? "Close" : "닫기"}
      </button>
    </div>
  </div>
</div>

<!-- Turnstile callback — reveals the iframe and loads it on demand -->
<script is:inline>
  window.onInquiryTurnstileSuccess = function () {
    var gate = document.querySelector('[data-inquiry-gate]');
    if (!gate) return;
    var challenge = gate.querySelector('[data-inquiry-challenge]');
    var iframe = gate.querySelector('[data-inquiry-iframe]');
    if (challenge) challenge.classList.add('hidden');
    if (iframe) {
      var url = iframe.getAttribute('data-src');
      if (url && iframe.getAttribute('src') !== url) iframe.setAttribute('src', url);
      iframe.classList.remove('hidden');
    }
  };
</script>

<!-- Cloudflare Turnstile API (loaded only when popup component is on the page) -->
<script
  is:inline
  src="https://challenges.cloudflare.com/turnstile/v0/api.js"
  async
  defer
></script>
