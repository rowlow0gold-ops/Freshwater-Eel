---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import BrandStory from "../../components/BrandStory.astro";
import Concept from "../../components/Concept.astro";
import Menu from "../../components/Menu.astro";
import Strategy from "../../components/Strategy.astro";
import Sales from "../../components/Sales.astro";
import Promo from "../../components/Promo.astro";
import Store from "../../components/Store.astro";
import Franchise from "../../components/Franchise.astro";
import Notice from "../../components/Notice.astro";
import Footer from "../../components/Footer.astro";
import PromoPopup from "../../components/PromoPopup.astro";
import InquiryPopup from "../../components/InquiryPopup.astro";
import InfoPopup from "../../components/InfoPopup.astro";
import FloatingCTA from "../../components/FloatingCTA.astro";
import StickyBottomBar from "../../components/StickyBottomBar.astro";
---

<Layout lang="en" path="/en/" title="Bonga Eel — Korean Premium Freshwater Eel Franchise">
  <Header />
  <main>
    <Hero       lang="en" />
    <BrandStory lang="en" />
    <Concept    lang="en" />
    <Menu       lang="en" />
    <Strategy   lang="en" />
    <Sales      lang="en" />
    <Promo      lang="en" />
    <Store      lang="en" />
    <Franchise  lang="en" />
    <Notice     lang="en" />
  </main>
  <Footer lang="en" />
  <PromoPopup lang="en" />
  <InquiryPopup lang="en" />
  <InfoPopup name="terms" lang="en" />
  <InfoPopup name="privacy" lang="en" />
  <FloatingCTA />
  <StickyBottomBar />
</Layout>
