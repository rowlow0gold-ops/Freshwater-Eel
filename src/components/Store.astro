---
import branchesKo from "../data/branches.json";
import branchesEn from "../data/en/branches.json";
import siteKo from "../data/site.json";
import siteEn from "../data/en/site.json";

interface Props { lang?: "ko" | "en"; }
const { lang = "ko" } = Astro.props;
const branches = lang === "en" ? branchesEn : branchesKo;
const site = lang === "en" ? siteEn : siteKo;

const mapSearchUrl = (address: string) =>
  lang === "en"
    ? `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(address)}`
    : `https://map.kakao.com/link/search/${encodeURIComponent(address)}`;
const hqLabel = lang === "en" ? "Headquarters" : "본점";
const mapCta = lang === "en" ? "Open in Google Maps →" : "카카오맵에서 보기 / Open in Kakao Map →";
---

<section id="store" class="py-24 bg-white">
  <div class="mx-auto max-w-6xl px-4">
    <h2 class="reveal text-3xl md:text-4xl font-extrabold text-center text-stone-900">
      {branches.title}
    </h2>
    <p class="reveal mt-4 text-center text-stone-600 max-w-2xl mx-auto">
      {branches.subtitle}
    </p>

    <!-- HQ map embed (Google Maps — clean UI, no 장소 저장/지도 설정) -->
    <div class="reveal mt-12 rounded-2xl overflow-hidden ring-1 ring-stone-200 bg-stone-100 aspect-[16/9] md:aspect-[16/7]">
      <iframe
        src={site.mapEmbedUrl}
        width="100%"
        height="100%"
        style="border:0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title={`${site.company.name} ${hqLabel}`}
      ></iframe>
    </div>
    <p class="reveal mt-3 text-center text-sm text-stone-500">
      {hqLabel} · {site.company.headOffice}
    </p>

    <!-- Branch list — big letter badges instead of photos -->
    <div data-reveal-children class="mt-16 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {branches.items.map((b, i) => (
        <article class="lift rounded-2xl overflow-hidden bg-[var(--color-cream)] ring-1 ring-stone-200 flex flex-col">
          <div class="aspect-[16/10] flex items-center justify-center bg-gradient-to-br from-[var(--color-brand)] to-[var(--color-brand-dark)] text-white">
            <span class="text-7xl md:text-8xl font-extrabold leading-none tracking-tight">
              {String.fromCharCode(65 + i)}
            </span>
          </div>
          <div class="p-5 flex-1 flex flex-col">
            <h3 class="text-lg font-bold text-[var(--color-brand)]">{b.name}</h3>
            <p class="mt-2 text-sm text-stone-700 flex-1">{b.address}</p>
            <a
              href={mapSearchUrl(b.address)}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-brand)] hover:underline self-start"
            >
              {mapCta}
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
