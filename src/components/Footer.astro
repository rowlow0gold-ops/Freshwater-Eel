---
import siteKo from "../data/site.json";
import siteEn from "../data/en/site.json";

interface Props {
  lang?: "ko" | "en";
}
const { lang = "ko" } = Astro.props;
const site = lang === "en" ? siteEn : siteKo;
const t = lang === "en";

const legal = t
  ? [
      { label: "Terms",   target: "terms" },
      { label: "Privacy", target: "privacy" },
    ]
  : [
      { label: "이용약관",         target: "terms" },
      { label: "개인정보처리방침", target: "privacy" },
    ];
---

<footer class="bg-stone-950 text-stone-300">
  <div class="h-0.5 w-full bg-gradient-to-r from-[var(--color-brand)] via-[var(--color-accent)] to-[var(--color-brand)]"></div>

  <div class="mx-auto max-w-6xl px-4 py-7">
    <!-- Row 1: brand + 문의 only -->
    <div class="flex flex-wrap items-center justify-between gap-y-3 gap-x-6">
      <div class="flex items-baseline gap-2">
        <span class="text-base font-extrabold text-white">{site.name}</span>
        <span class="text-[10px] tracking-[0.25em] text-stone-500 uppercase">{site.nameEn}</span>
      </div>
      <button
        type="button"
        data-popup-open="inquiry"
        class="rounded-full bg-[var(--color-brand)] hover:bg-[var(--color-brand-dark)] text-white px-4 py-1.5 text-xs font-semibold transition"
      >
        {t ? "Contact" : "문의"}
      </button>
    </div>

    <!-- Divider + dense bottom row -->
    <div class="mt-5 pt-4 border-t border-stone-800 flex flex-wrap gap-x-4 gap-y-1 text-[11px] leading-relaxed text-stone-500">
      <span>
        {site.company.name} · {t ? "CEO" : "대표"} {site.company.ceo} · {site.company.bizId}
        · {t ? "HQ" : "본점"} {site.company.headOffice}
        · {site.phone} · {site.email}
      </span>
      <span class="flex flex-wrap gap-x-3 ml-auto">
        {legal.map((l) => (
          <button
            type="button"
            data-popup-open={l.target}
            class="hover:text-white transition"
          >
            {l.label}
          </button>
        ))}
        <span class="text-stone-600">© {site.nameEn}</span>
      </span>
    </div>
  </div>
</footer>
